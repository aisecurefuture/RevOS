# ============================================================================
# RevOS PRODUCTION environment — revos360.com
# ----------------------------------------------------------------------------
# Copy to ".env" on the server and fill in the secrets. The app FAILS TO BOOT
# if production config is insecure (default secret, COOKIE_SECURE=false, etc.).
# ============================================================================

# --- Core ---
APP_ENV=production
DEBUG=false
APP_NAME=RevOS

# Public URLs (Caddy routes these hostnames):
APP_BASE_URL=https://api.revos360.com         # API base (links, webhooks)
PUBLIC_BASE_URL=https://api.revos360.com       # opt-in / unsubscribe / landing / UTM links
FRONTEND_BASE_URL=https://app.revos360.com     # admin console
CORS_ORIGINS=https://app.revos360.com

# REQUIRED: generate with  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Behind Caddy (a trusted proxy) — trust X-Forwarded-For for rate limiting.
TRUST_PROXY=true

# --- Cookies / auth (must be secure in production) ---
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# First admin (created by the seed). Use a strong password and change it after.
OWNER_EMAIL=patrickkelly2024@u.northwestern.edu
OWNER_PASSWORD=
OWNER_NAME=Patrick Kelly

# --- Database / Redis ---
DATABASE_URL=postgresql+asyncpg://revos:CHANGE_ME@db:5432/revos
POSTGRES_USER=revos
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=revos
REDIS_URL=redis://redis:6379/0

# --- Email: Resend ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_TEST_MODE=true            # set false once your sending domain is verified
DEFAULT_FROM_EMAIL=no-reply@revos360.com
DEFAULT_FROM_NAME=RevOS

# --- Payments / AI / storage / analytics (optional; see .env.example for all) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
AI_PROVIDER=none
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# --- Local models (Ollama) — uncomment to run Gemma + Qwen on-box ---
# AI_PROVIDER=local
# LOCAL_AI_BASE_URL=http://ollama:11434/v1
# LOCAL_AI_MODEL=qwen2.5:7b
# LOCAL_AI_MODEL_MAP={"social":"gemma2:9b","landing":"gemma2:9b"}
STORAGE_BACKEND=local           # or s3 — set S3_* if using object storage
ZAPIER_WEBHOOK_SECRET=

# --- SSRF allowlist (hosts the server may fetch, e.g. for link previews) ---
SSRF_ALLOWED_HOSTS=
