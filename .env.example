# ============================================================================
# RevOS environment configuration
# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in values. NEVER commit a real .env.
# Optional integrations may be left blank — RevOS degrades gracefully and
# falls back to mock / draft / copy-paste mode when a key is missing.
# ============================================================================

# --- Core application -------------------------------------------------------
APP_ENV=development                 # development | staging | production
DEBUG=true                          # MUST be false in production
APP_NAME=RevOS
# Public URL of the API (used to build unsubscribe links, opt-in links, etc.)
APP_BASE_URL=http://localhost:8000
# Public URL of the admin frontend
FRONTEND_BASE_URL=http://localhost:3000
# Public URL where hosted landing pages / forms are served
PUBLIC_BASE_URL=http://localhost:8000

# SECRET_KEY is REQUIRED. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-generate-a-long-random-value

# Comma-separated list of allowed CORS origins for the admin dashboard.
CORS_ORIGINS=http://localhost:3000

# Only set true when behind a known reverse proxy — otherwise X-Forwarded-For
# is attacker-controlled and would let clients spoof their IP (rate-limit bypass).
TRUST_PROXY=false
# Hard ceiling on any request body in bytes (global DoS backstop; default 256MB).
MAX_REQUEST_BYTES=268435456

# --- Database ---------------------------------------------------------------
# Async driver (asyncpg) is used by the API; Alembic derives the sync URL.
DATABASE_URL=postgresql+asyncpg://revos:revos@db:5432/revos
# These are consumed by the postgres container in docker-compose.
POSTGRES_USER=revos
POSTGRES_PASSWORD=revos
POSTGRES_DB=revos

# --- Redis (Celery broker + cache + rate limiting) --------------------------
REDIS_URL=redis://redis:6379/0

# --- Auth / security --------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ALGORITHM=HS256
# Cookie security — set SECURE=true behind HTTPS in production.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Login throttling
LOGIN_RATE_LIMIT=5/minute

# First owner account auto-created on first `seed`. Change the password!
OWNER_EMAIL=patrickkelly2024@u.northwestern.edu
OWNER_PASSWORD=change-me-strong-password
OWNER_NAME=Patrick Kelly

# --- Email: Resend (optional — test mode if blank) --------------------------
# Get an API key at https://resend.com and verify your sending domains.
RESEND_API_KEY=
# Svix signing secret for Resend status webhooks (starts with "whsec_").
RESEND_WEBHOOK_SECRET=
# When true, emails are NOT sent — they are logged/stored for inspection.
# Auto-forced true if RESEND_API_KEY is blank.
EMAIL_TEST_MODE=true
# Fallback sender used when a brand has no verified SenderIdentity yet.
DEFAULT_FROM_EMAIL=no-reply@example.com
DEFAULT_FROM_NAME=RevOS

# --- AI provider (optional — draft generation degrades to templates) --------
# AI_PROVIDER: anthropic | openai | local | none
AI_PROVIDER=none
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Local/self-hosted model endpoint.
# - Bare Ollama URL (e.g. http://ollama:11434) -> native /api/chat, with
#   thinking disabled. REQUIRED for reasoning models (Gemma 4, Qwen 3.5+):
#   their OpenAI-compatible /v1 endpoint puts all output in a hidden
#   "reasoning" field and returns empty content (ollama/ollama#15288).
# - URL ending in /v1 (Ollama's OpenAI-compatible path, vLLM, etc.) -> the
#   generic OpenAI-SDK path. Fine for non-reasoning models.
LOCAL_AI_BASE_URL=
# Default model for the local provider (e.g. an Ollama tag). Falls back to OPENAI_MODEL.
LOCAL_AI_MODEL=
# Optional per-use-case model routing for the local provider, as a JSON object.
# Keys: email, social, landing, ideas, summary. Unlisted use-cases use LOCAL_AI_MODEL.
# e.g. LOCAL_AI_MODEL_MAP={"email":"qwen2.5:7b","social":"gemma2:9b"}
LOCAL_AI_MODEL_MAP=
# Hard cap on AI calls/min to control cost (OWASP LLM rate limiting)
AI_RATE_LIMIT=20/minute

# --- Payments: Stripe (optional) --------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- File storage (optional S3-compatible; local fs by default) -------------
STORAGE_BACKEND=local               # local | s3
STORAGE_LOCAL_DIR=./storage
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# --- Privacy-friendly analytics (all optional) ------------------------------
PLAUSIBLE_DOMAIN=
PLAUSIBLE_API_KEY=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
GA_MEASUREMENT_ID=

# --- Social adapters (optional — draft-only without keys; NO scraping) ------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
YOUTUBE_API_KEY=

# Low-cost integrations (Calendly, Notion, Bitly, Zapier, Google Sheets) are
# configured per-account in the app at Settings → Integrations — no env vars.

# --- SSRF allowlist ---------------------------------------------------------
# Comma-separated hostnames the server is permitted to fetch (link previews,
# outbound webhooks). Empty = block all server-side fetches of user URLs.
SSRF_ALLOWED_HOSTS=
